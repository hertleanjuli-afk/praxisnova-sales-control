# PraxisNova Sales Control – Umgebungsvariablen
# Kopiere als .env.local und fülle die Werte aus

# ── Datenbank ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/database

# ── Authentifizierung (Dashboard-Login) ────────────────────
USER_1_EMAIL=
USER_1_PASSWORD=
USER_2_EMAIL=
USER_2_PASSWORD=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Cron Jobs ──────────────────────────────────────────────
CRON_SECRET=

# ── Admin Endpoints ───────────────────────────────────────
ADMIN_SECRET=

# ── HubSpot CRM ───────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=

# ── Brevo (E-Mail) ────────────────────────────────────────
BREVO_API_KEY=
BREVO_WEBHOOK_SECRET=

# ── Webhook (Website → Sales Control) ─────────────────────
INBOUND_WEBHOOK_SECRET=

# ── Brevo Absender (pro Branche, optional) ─────────────────
BREVO_SENDER_EMAIL_PRIMARY=info@praxisnovaai.com
BREVO_SENDER_EMAIL_FALLBACK=hertle.anjuli@praxisnovaai.com
BREVO_SENDER_NAME=Anjuli Hertle
BREVO_SENDER_IMMOBILIEN_EMAIL=
BREVO_SENDER_IMMOBILIEN_NAME=
BREVO_SENDER_HANDWERK_EMAIL=
BREVO_SENDER_HANDWERK_NAME=
BREVO_SENDER_BAU_EMAIL=
BREVO_SENDER_BAU_NAME=
BREVO_SENDER_INBOUND_EMAIL=
BREVO_SENDER_INBOUND_NAME=

# ── Apollo (Lead-Recherche, optional) ──────────────────────
APOLLO_API_KEY=

# ── Gmail Reply Sync (Paket A, 2026-04-11) ────────────────
# One-time OAuth bootstrap required. See SETUP-gmail-reply-sync.md.
# If all three are empty, the gmail-reply-sync cron skips with
# status=not_configured (no errors, no crashes).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── LLM Provider (Phase 1 Multi-Provider Abstraction) ─────
# Default-Provider wenn kein Agent-Override in AGENT_LLM_CONFIG
DEFAULT_LLM_PROVIDER=gemini-paid
# Gemini Paid (AI Studio Billed, EU Region)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
# Gemini Free (AI Studio Free Tier, EU Region)
GEMINI_FREE_API_KEY=
GEMINI_FREE_MODEL=gemini-2.5-flash
# Groq (Llama 3.3 70B Versatile)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional Admin-Token fuer /api/admin/llm-config (alternativ zu CRON_SECRET)
ADMIN_TOKEN=

# ── Observability Push-Channels (lib/observability/logger.ts) ─────────
# Beide optional. Wenn nicht gesetzt, wird nur in die Konsole geloggt.
# observe.error sendet parallel an beide Kanaele via Promise.allSettled,
# ein Ausfall blockiert den anderen nicht.

# Slack Incoming-Webhook URL. Format: https://hooks.slack.com/services/T.../B.../...
SLACK_ALERT_WEBHOOK=

# ntfy.sh Topic-URL. Angie nutzt die iOS-App statt Slack.
# Push-Test bestanden 2026-04-18. Topic ist Secret-Replacement (URL = Secret).
NTFY_TOPIC_URL=https://ntfy.sh/praxisnovaai-alerts-task110

# ── Öffentliche Variablen ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.praxisnovaai.com
NEXT_PUBLIC_CALENDLY_LINK=https://calendly.com/meyer-samantha-praxisnovaai/erstgesprach
NEXT_PUBLIC_TIKTOK_MODULE_ENABLED=false
NEXT_PUBLIC_APOLLO_CONFIGURED=false
NEXT_PUBLIC_HUBSPOT_CONFIGURED=true
NEXT_PUBLIC_BREVO_CONFIGURED=true
